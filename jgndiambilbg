local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local LP = Players.LocalPlayer

-- ============================================
-- [1] PERFORMANCE OPTIMIZER
-- ============================================

-- Kualitas grafis minimum
settings().Rendering.QualityLevel = Enum.QualityLevel.Level01

-- Matikan shadow & fog
Lighting.GlobalShadows = false
Lighting.FogEnd = 9e9

-- Matikan efek Lighting
for _, fx in ipairs(Lighting:GetChildren()) do
    if fx:IsA("BlurEffect")
    or fx:IsA("DepthOfFieldEffect")
    or fx:IsA("SunRaysEffect")
    or fx:IsA("BloomEffect")
    or fx:IsA("ColorCorrectionEffect") then
        fx.Enabled = false
    end
end

-- Matikan semua efek visual di workspace
local function cleanEffects(parent)
    for _, v in ipairs(parent:GetDescendants()) do
        if v:IsA("ParticleEmitter")
        or v:IsA("Trail")
        or v:IsA("Smoke")
        or v:IsA("Fire")
        or v:IsA("Sparkles") then
            v.Enabled = false
        end
    end
end
cleanEffects(workspace)

-- Auto-clean efek dari objek yang baru masuk workspace
workspace.DescendantAdded:Connect(function(v)
    if v:IsA("ParticleEmitter")
    or v:IsA("Trail")
    or v:IsA("Smoke")
    or v:IsA("Fire")
    or v:IsA("Sparkles") then
        v.Enabled = false
    end
end)

print("[OPT] Performance optimizer aktif!")

-- ============================================
-- [2] AUTO SET TRADE -> EVERYONE
-- ============================================

local API = ReplicatedStorage:WaitForChild("API", 10)

if not API then
    warn("[TRADE] API folder tidak ditemukan! Script dihentikan.")
    return
end

local remote = nil

-- Coba nama remote yang diketahui dulu
remote = API:FindFirstChild("cpEFwBwISicUoAQrDTUKQK")

-- Jika tidak ada (nama berubah karena update), scan otomatis
if not remote then
    print("[SCAN] Remote lama tidak ditemukan, scanning...")
    for _, v in ipairs(API:GetChildren()) do
        if v:IsA("RemoteEvent") and #v.Name > 15 then
            local ok = pcall(function()
                v:FireServer("trade_requests", 1)
            end)
            if ok then
                remote = v
                print("[SCAN] Remote ditemukan: " .. v.Name)
                break
            end
        end
    end
end

-- Fire remote untuk set trade ke Everyone
if remote then
    pcall(function()
        remote:FireServer("trade_requests", 1)
    end)
    task.wait(2)
    print("[TRADE] Trade berhasil di-set ke Everyone!")
else
    warn("[TRADE] Remote tidak ditemukan! Cek update Adopt Me terbaru.")
end

